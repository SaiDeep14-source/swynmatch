{
  "functions": {
    "api/gemini/generateContent.ts": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/proxy-sheet.ts": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/gemini/generateContent",
      "destination": "/api/gemini/generateContent"
    },
    {
      "source": "/api/proxy-sheet",
      "destination": "/api/proxy-sheet"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
